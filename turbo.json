{
	"$schema": "https://v2-10-3.turborepo.dev/schema.json",
	"globalEnv": [
		"NODE_ENV",
		"PLAYWRIGHT_BROWSERS_PATH",
		"PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS",
		"PLAYWRIGHT_HOST_PLATFORM_OVERRIDE",
		"LD_LIBRARY_PATH"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".output/**", "dist/**", "genql/**"]
		},
		"dev": {
			"dependsOn": ["@politigraph/graphql#build", "migrate"],
			"persistent": true,
			"cache": false
		},
		"migrate": {
			"cache": false
		},
		"lint": {
			"cache": false
		},
		"check": {
			"dependsOn": ["^build"],
			"cache": false
		},
		"@politigraph/graphql#check": {
			"dependsOn": ["build"],
			"cache": false
		},
		"test:unit": {
			"cache": false
		},
		"test:integration": {
			"cache": false
		},
		"test:e2e": {
			"cache": false,
			"dependsOn": ["^build", "@politigraph/auth#migrate"]
		}
	}
}
