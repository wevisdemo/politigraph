{
	"$schema": "https://v2-10-3.turborepo.dev/schema.json",
	"globalEnv": [
		"BETTER_AUTH_SECRET",
		"BETTER_AUTH_URL",
		"DATABASE_URL",
		"LD_LIBRARY_PATH",
		"NEO4J_PASSWORD",
		"NEO4J_URI",
		"NEO4J_USERNAME",
		"NODE_ENV",
		"PLAYWRIGHT_BROWSERS_PATH",
		"PLAYWRIGHT_HOST_PLATFORM_OVERRIDE",
		"PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS",
		"POLITIGRAPH_URL",
		"PORT",
		"POSTGRES_PASSWORD"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".output/**", "dist/**", "genql/**"]
		},
		"dev": {
			"dependsOn": ["@politigraph/graphql#build", "migrate"],
			"persistent": true,
			"cache": false
		},
		"migrate": {
			"cache": false
		},
		"lint": {
			"cache": false
		},
		"check": {
			"dependsOn": ["^build"],
			"cache": false
		},
		"@politigraph/graphql#check": {
			"dependsOn": ["build"],
			"cache": false
		},
		"test:unit": {
			"cache": false
		},
		"test:integration": {
			"dependsOn": ["^migrate"],
			"cache": false
		},
		"test:e2e": {
			"dependsOn": ["^build", "^seed"],
			"cache": false
		},
		"seed": {
			"dependsOn": ["migrate"],
			"cache": false
		}
	}
}
