{
	"$schema": "https://v2-10-3.turborepo.dev/schema.json",
	"tasks": {
		"test": {
			"cache": false
		},
		"test:unit": {
			"cache": false
		},
		"test:integration": {
			"cache": false
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".output/**", "dist/**", "genql/**"],
			"env": ["NODE_ENV"]
		},
		"dev": {
			"dependsOn": ["@politigraph/graphql#build", "migrate"],
			"persistent": true,
			"cache": false
		},
		"migrate": {
			"cache": false
		},
		"lint": {
			"cache": false
		},
		"check": {
			"dependsOn": ["^build"],
			"cache": false
		},
		"@politigraph/graphql#check": {
			"dependsOn": ["build"],
			"cache": false
		}
	}
}
