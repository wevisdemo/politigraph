---
import { Code, TabItem, Tabs } from '@astrojs/starlight/components';
import * as graphql from 'prettier/plugins/graphql';
import { format } from 'prettier/standalone';
import { fetchGraphql } from '../utils/graphql';
import QueryGraph from './query-graph.vue';

interface Props {
	query: string;
	variables?: string;
}

const { query, variables } = Astro.props;

const parsedVariables = variables ? JSON.parse(variables) : undefined;
const jsonResponse = await fetchGraphql(query, parsedVariables);

const flattenedData = Object.values(jsonResponse.data).flatMap(([value]) => {
	if (Array.isArray(value)) {
		return value.map((item) => ({
			...item,
		}));
	}
	return value;
});

const formattedQuery = await format(query, {
	parser: 'graphql',
	plugins: [graphql],
});

function formatJson(obj: Object) {
	return JSON.stringify(obj, null, 2);
}
---

<Tabs>
	<TabItem label="Visualization">
		<QueryGraph client:visible data={{ flattenedData }} />
	</TabItem>
	<TabItem label="Query">
		<Code
			code={formattedQuery}
			lang="graphql"
			class="md:h-128 overflow-y-auto"
		/>
	</TabItem>
	{
		variables && (
			<TabItem label="Variables">
				<Code
					code={formatJson(JSON.parse(variables))}
					lang="json"
					class="md:h-128 overflow-y-auto"
				/>
			</TabItem>
		)
	}
	<TabItem label="Response">
		<Code
			code={formatJson(jsonResponse)}
			lang="json"
			class="md:h-128 overflow-y-auto"
		/>
	</TabItem>
</Tabs>
