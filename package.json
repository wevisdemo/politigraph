{
	"name": "politigraph",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"prepare": "husky",
		"dev": "turbo dev",
		"build": "turbo build",
		"lint": "turbo lint --concurrency=1",
		"check": "turbo check",
		"format": "prettier --write --ignore-unknown --ignore-path .gitignore .",
		"test:unit": "turbo test:unit",
		"test:integration": "turbo test:integration",
		"db:pull": "rsync -azvP --delete politigraphdb:/var/server/neo4j/data .neo4j"
	},
	"lint-staged": {
		"*": "prettier --write --ignore-unknown"
	},
	"packageManager": "bun@1.3.2",
	"dependencies": {
		"turbo": "^2.10.3"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.6.0",
		"@commitlint/config-conventional": "^19.6.0",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.4.0",
		"astro-eslint-parser": "^2.1.0",
		"eslint": "^9.25.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-astro": "^2.1.1",
		"husky": "^9.1.7",
		"lint-staged": "^15.2.11",
		"prettier": "^3.6.2",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.6.13",
		"typescript-eslint": "^8.62.1"
	}
}
