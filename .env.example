# ── Postgres ──────────────────────────────────────
# POSTGRES_PASSWORD initializes the Docker container.
# DATABASE_URL must embed the SAME password.
POSTGRES_PASSWORD=localdevonly
DATABASE_URL=postgresql://postgres:localdevonly@127.0.0.1:5432/betterauth

# ── Neo4j ─────────────────────────────────────────
# Same creds used by Docker container NEO4J_AUTH AND app connection.
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_URI=neo4j://127.0.0.1:7687

# ── Better Auth ───────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ── Docs (Astro) ─────────────────────────────────
PUBLIC_POLITIGRAPH_URL=http://localhost:3000/graphql

# ── Server ────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Env Loading ───────────────────────────────────
# @politigraph/config loads env in this order:
#   1. .env               (baseline)
#   2. .env.{NODE_ENV}    (overrides, e.g. .env.production)
# All files are optional. NODE_ENV defaults to 'development'.
